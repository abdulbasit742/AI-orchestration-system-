# Configure at least one provider. Keep real values in .env.local or your host's secret manager.

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# OpenAI-compatible providers
OPENAI_API_KEY=
OPENAI_MODEL=
GROQ_API_KEY=
GROQ_MODEL=
TOGETHER_API_KEY=
TOGETHER_MODEL=

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=

# Local Ollama: loopback HTTP only to prevent server-side request forgery.
OLLAMA_ENABLED=false
OLLAMA_MODEL=
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Orchestration controls
ORCHESTRATOR_PROVIDER_ORDER=ollama,anthropic,openai,groq,together,gemini,demo
ORCHESTRATOR_TIMEOUT_MS=25000
ORCHESTRATOR_MAX_PROVIDER_ATTEMPTS=3
ORCHESTRATOR_DEMO_MODE=false
